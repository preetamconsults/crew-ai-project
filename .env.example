# Copy this file to `.env` (never commit `.env` тАФ it's in .gitignore).
# On CrewAI AMP, set these in the deployment dashboard's Environment tab,
# NOT in the code or repo.
#
# This crew uses Azure OpenAI (NOT direct OpenAI). Do not set OPENAI_API_KEY.

# ---- Azure OpenAI (REQUIRED) ----
# Get these from your Azure portal -> Azure OpenAI resource -> Keys & Endpoint.
AZURE_API_KEY=replace-me
AZURE_API_BASE=https://<your-resource-name>.openai.azure.com
AZURE_API_VERSION=2024-08-01-preview

# Deployment NAMES (NOT the underlying model names) you configured in Azure
# OpenAI Studio. Defaults assume you named them "gpt-4o" and "gpt-4o-mini".
# If your Azure deployments use different names, set these to match.
AZURE_GPT4O_DEPLOYMENT=gpt-4o
AZURE_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini

# ---- Tavily web search (REQUIRED) ----
# Free tier at https://tavily.com gives 1,000 search credits/month.
TAVILY_API_KEY=tvly-replace-me
