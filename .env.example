# Copy this file to `.env` (never commit `.env` тАФ it's in .gitignore).
# On CrewAI AMP, set these in the deployment dashboard's Environment tab,
# NOT in the code or repo.

# Required: powers all agent LLMs (gpt-4o, gpt-4o-mini)
OPENAI_API_KEY=sk-replace-me

# Required: powers the source scout's targeted web search.
# Free tier at https://tavily.com gives 1,000 search credits/month.
TAVILY_API_KEY=tvly-replace-me

# Optional: override the default model
# MODEL=gpt-4o
